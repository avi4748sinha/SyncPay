# Server
PORT=4000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/syncpay

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d

# OTP (optional - use Redis TTL for dev)
OTP_EXPIRE_SECONDS=300

# Twilio SMS (for OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
OTP_SMS_COUNTRY_CODE=91

# Offline limit default (in paise/cents for precision)
DEFAULT_OFFLINE_LIMIT=500000
